    "s=\"([])\"\n",
    "st=[]\n",
    "c_d={'}':'{',')':'(',']':'['}\n",
    "for c in s:\n",
    "    if c in c_d:\n",
    "        if st and st[-1]== c_d[c]:\n",
    "            st.pop()\n",
    "        else:\n",
    "            return False\n",
    "    else:\n",
    "        st.append(c)\n",
    "return True if not st else False"
   ]
