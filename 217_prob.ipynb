    "#217\n",
    "class Solution(object):\n",
    "    def containsDuplicate(self, nums):\n",
    "        h=set()\n",
    "        for i in nums:\n",
    "            h.add(i)\n",
    "        if len(h)==len(nums):\n",
    "            return False\n",
    "        else:\n",
    "            return True"
   ]
  }
